# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# API key encryption (AES-256-GCM) — must be base64-encoded 32 bytes
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Google OAuth
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Scopes needed: openid email profile https://www.googleapis.com/auth/drive.file
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
