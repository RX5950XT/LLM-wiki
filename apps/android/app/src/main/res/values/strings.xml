    <!-- Help -->
    <string name="help_title">Help</string>
    <string name="help_workspace_title">Workspaces and pages</string>
    <string name="help_workspace_body">Use the workspace menu to switch, reorder, or create a workspace. Knowledge pages are LLM-maintained, notes are yours, and rule pages contain the prompts and control files that steer the LLM.</string>
    <string name="help_ingest_title">Import content</string>
    <string name="help_ingest_body">Use + to paste a URL, text, or Markdown. Use the attachment button to import a text file from your phone.</string>
    <string name="help_chat_title">Chat and synthesis</string>
    <string name="help_chat_body">Open Chat to ask your wiki questions. Choose a model profile in the chat bar, then save useful answers as synthesis pages.</string>
    <string name="help_settings_title">Settings and profiles</string>
    <string name="help_settings_body">Settings manages LLM profiles, language, and appearance. Profiles are synced through your Supabase account.</string>
    <string name="help_drive_title">Google Drive reconnect</string>
    <string name="help_drive_body">If Drive permission expires, reconnect in the browser and return to the app. The app will refresh workspace and profile data after reconnecting.</string>
    <string name="workspace_create_menu_hint">Add another Drive-backed wiki</string>

