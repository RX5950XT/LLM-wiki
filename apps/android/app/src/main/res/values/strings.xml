    <!-- Help -->
    <string name="help_title">Help</string>
    <string name="help_workspace_title">Workspaces and pages</string>
    <string name="help_workspace_body">Use the workspace menu to switch, reorder, or create a workspace. Knowledge pages are AI-maintained; the lock icon protects a page from AI overwrites. You can also ask the AI in chat to create, rename, or delete workspaces.</string>
    <string name="help_ingest_title">Import content</string>
    <string name="help_ingest_body">Open chat, then tap the bot button left of the input → "Import content" or "Import from file". The target workspace defaults to "Auto", letting the AI decide where the content belongs.</string>
    <string name="help_chat_title">Chat and synthesis</string>
    <string name="help_chat_body">Chat defaults to the page you are viewing as context; type "@" to tag another workspace as extra context. The AI files valuable content into knowledge pages; destructive actions show a confirmation card first (switchable in Settings). The wand button in the drawer runs auto-classify + dedupe across all workspaces.</string>
    <string name="help_settings_title">Settings and profiles</string>
    <string name="help_settings_body">Settings manages LLM profiles, language, appearance, and rules. Rules are the prompt files that control ingest, query, and health checks.</string>
    <string name="help_drive_title">Google Drive reconnect</string>
    <string name="help_drive_body">If Drive permission expires, reconnect in the browser and return to the app. The app will refresh workspace and profile data after reconnecting.</string>
    <string name="workspace_create_menu_hint">Add another Drive-backed wiki</string>

