    <!-- 使用說明 -->
    <string name="help_title">使用說明</string>
    <string name="help_workspace_title">工作區與頁面</string>
    <string name="help_workspace_body">用工作區選單切換、排序或建立工作區。知識頁由 LLM 維護；筆記可新增、重新命名、刪除並用 Markdown 編輯。</string>
    <string name="help_ingest_title">匯入內容</string>
    <string name="help_ingest_body">用 + 貼上網址、文字或 Markdown。用附加檔案按鈕可從手機匯入文字檔。</string>
    <string name="help_chat_title">對話與綜合頁</string>
    <string name="help_chat_body">打開對話詢問 Wiki。可在輸入列選模型設定檔，並將有用回答存成綜合頁面。</string>
    <string name="help_settings_title">設定與 LLM 設定檔</string>
    <string name="help_settings_body">設定頁管理 LLM profile、語言、外觀與規則。規則是控制匯入、查詢與健康檢查的提示詞檔。</string>
    <string name="help_drive_title">Google Drive 重新連線</string>
    <string name="help_drive_body">若 Drive 授權失效，請在瀏覽器重新授權後回到 App，App 會重新整理工作區與設定檔。</string>
