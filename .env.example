# =========================================================================
# LLM Wiki — environment variables
#
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local`.
# =========================================================================

# --- Supabase (metadata + realtime + auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Encryption key for user-supplied LLM API keys ---
# 32-byte base64 string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# --- Google OAuth (with drive.file scope) ---
# From https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Public site URL (used for OAuth redirects) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
